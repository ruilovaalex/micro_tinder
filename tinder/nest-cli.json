{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "../api-gateway",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false,
    "tsConfigPath": "../api-gateway/tsconfig.app.json"
  },
  "projects": {
    "contracts": {
      "type": "library",
      "root": "libs/contracts",
      "entryFile": "index",
      "sourceRoot": "libs/contracts/src",
      "compilerOptions": {
        "tsConfigPath": "libs/contracts/tsconfig.lib.json"
      }
    },
    "api-gateway": {
      "type": "application",
      "root": "../api-gateway",
      "entryFile": "main",
      "sourceRoot": "../api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "../api-gateway/tsconfig.app.json"
      }
    },
    "auth-service": {
      "type": "application",
      "root": "../auth-service",
      "entryFile": "main",
      "sourceRoot": "../auth-service/src",
      "compilerOptions": {
        "tsConfigPath": "../auth-service/tsconfig.app.json"
      }
    },
    "users-service": {
      "type": "application",
      "root": "../users-service",
      "entryFile": "main",
      "sourceRoot": "../users-service/src",
      "compilerOptions": {
        "tsConfigPath": "../users-service/tsconfig.app.json"
      }
    },
    "profiles-service": {
      "type": "application",
      "root": "../profiles-service",
      "entryFile": "main",
      "sourceRoot": "../profiles-service/src",
      "compilerOptions": {
        "tsConfigPath": "../profiles-service/tsconfig.app.json"
      }
    },
    "interactions-service": {
      "type": "application",
      "root": "../interactions-service",
      "entryFile": "main",
      "sourceRoot": "../interactions-service/src",
      "compilerOptions": {
        "tsConfigPath": "../interactions-service/tsconfig.app.json"
      }
    },
    "matches-service": {
      "type": "application",
      "root": "../matches-service",
      "entryFile": "main",
      "sourceRoot": "../matches-service/src",
      "compilerOptions": {
        "tsConfigPath": "../matches-service/tsconfig.app.json"
      }
    },
    "messages-service": {
      "type": "application",
      "root": "../messages-service",
      "entryFile": "main",
      "sourceRoot": "../messages-service/src",
      "compilerOptions": {
        "tsConfigPath": "../messages-service/tsconfig.app.json"
      }
    },
    "subscriptions-service": {
      "type": "application",
      "root": "../subscriptions-service",
      "entryFile": "main",
      "sourceRoot": "../subscriptions-service/src",
      "compilerOptions": {
        "tsConfigPath": "../subscriptions-service/tsconfig.app.json"
      }
    }
  }
}
