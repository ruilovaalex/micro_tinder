{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "../api-gateway",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false,
    "tsConfigPath": "../api-gateway/tsconfig.app.json"
  },
  "projects": {
    "contracts": {
      "type": "library",
      "root": "libs/contracts",
      "entryFile": "index",
      "sourceRoot": "libs/contracts/src",
      "compilerOptions": {
        "tsConfigPath": "libs/contracts/tsconfig.lib.json"
      }
    },
    "api-gateway": {
      "type": "application",
      "root": "../api-gateway",
      "entryFile": "main",
      "sourceRoot": "../api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "../api-gateway/tsconfig.app.json"
      }
    },
    "auth-service": {
      "type": "application",
      "root": "../auth-service",
      "entryFile": "main",
      "sourceRoot": "../auth-service/src",
      "compilerOptions": {
        "tsConfigPath": "../auth-service/tsconfig.app.json"
      }
    },
    "tinder-service": {
      "type": "application",
      "root": "../tinder-service",
      "entryFile": "main",
      "sourceRoot": "../tinder-service/src",
      "compilerOptions": {
        "tsConfigPath": "../tinder-service/tsconfig.app.json"
      }
    }
  }
}
