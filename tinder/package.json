{
  "name": "tinder",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "npm run prisma:generate",
    "build": "nest build contracts && nest build api-gateway && nest build auth-service && nest build tinder-service",
    "format": "prettier --write \"../api-gateway/src/**/*.ts\" \"../auth-service/src/**/*.ts\" \"../tinder-service/src/**/*.ts\" \"libs/**/*.ts\" \"test/**/*.ts\"",
    "prisma:generate": "npm run prisma:generate:auth && npm run prisma:generate:tinder",
    "prisma:generate:auth": "prisma generate --config ../auth-service/prisma.config.ts",
    "prisma:generate:tinder": "prisma generate --config ../tinder-service/prisma.config.ts",
    "prisma:migrate:dev:auth": "prisma migrate dev --config ../auth-service/prisma.config.ts",
    "prisma:migrate:dev:tinder": "prisma migrate dev --config ../tinder-service/prisma.config.ts",
    "prisma:migrate:deploy:auth": "prisma migrate deploy --config ../auth-service/prisma.config.ts",
    "prisma:migrate:deploy:tinder": "prisma migrate deploy --config ../tinder-service/prisma.config.ts",
    "prisma:migrate:status:auth": "prisma migrate status --config ../auth-service/prisma.config.ts",
    "prisma:migrate:status:tinder": "prisma migrate status --config ../tinder-service/prisma.config.ts",
    "prisma:seed:auth": "ts-node ../auth-service/prisma/seed.ts",
    "start": "nest start api-gateway",
    "start:dev": "nest start api-gateway --watch",
    "start:dev:gateway": "nest start api-gateway --watch",
    "start:dev:auth": "nest start auth-service --watch",
    "start:dev:tinder": "nest start tinder-service --watch",
    "start:prod:gateway": "node dist/apps/api-gateway/main",
    "start:prod:auth": "node dist/apps/auth-service/main",
    "start:prod:tinder": "node dist/apps/tinder-service/main",
    "lint": "eslint \"{../api-gateway/src,../auth-service/src,../tinder-service/src,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.9",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/bcrypt": "^6.0.0",
    "@types/passport-jwt": "^4.0.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.2.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.spec.json"
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "collectCoverageFrom": [
      "../api-gateway/src/**/*.(t|j)s",
      "../auth-service/src/**/*.(t|j)s",
      "../tinder-service/src/**/*.(t|j)s",
      "libs/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  }
}
