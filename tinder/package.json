{
  "name": "tinder",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "npm run prisma:generate",
    "build": "nest build contracts && nest build api-gateway && nest build auth-service && nest build users-service && nest build profiles-service && nest build interactions-service && nest build matches-service && nest build messages-service && nest build subscriptions-service && node ./scripts/post-build.js",
    "build:contracts": "nest build contracts",
    "format": "prettier --write \"../api-gateway/src/**/*.ts\" \"../auth-service/src/**/*.ts\" \"../users-service/src/**/*.ts\" \"../profiles-service/src/**/*.ts\" \"../interactions-service/src/**/*.ts\" \"../matches-service/src/**/*.ts\" \"../messages-service/src/**/*.ts\" \"../subscriptions-service/src/**/*.ts\" \"libs/**/*.ts\" \"test/**/*.ts\"",
    "prisma:generate": "npm run prisma:generate:auth && npm run prisma:generate:users && npm run prisma:generate:profiles && npm run prisma:generate:interactions && npm run prisma:generate:matches && npm run prisma:generate:messages && npm run prisma:generate:subscriptions",
    "prisma:generate:auth": "prisma generate --config ../auth-service/prisma.config.ts",
    "prisma:generate:users": "prisma generate --config ../users-service/prisma.config.ts",
    "prisma:generate:profiles": "prisma generate --config ../profiles-service/prisma.config.ts",
    "prisma:generate:interactions": "prisma generate --config ../interactions-service/prisma.config.ts",
    "prisma:generate:matches": "prisma generate --config ../matches-service/prisma.config.ts",
    "prisma:generate:messages": "prisma generate --config ../messages-service/prisma.config.ts",
    "prisma:generate:subscriptions": "prisma generate --config ../subscriptions-service/prisma.config.ts",
    "prisma:migrate:dev:auth": "prisma migrate dev --config ../auth-service/prisma.config.ts",
    "prisma:migrate:dev:users": "prisma migrate dev --config ../users-service/prisma.config.ts",
    "prisma:migrate:dev:profiles": "prisma migrate dev --config ../profiles-service/prisma.config.ts",
    "prisma:migrate:dev:interactions": "prisma migrate dev --config ../interactions-service/prisma.config.ts",
    "prisma:migrate:dev:matches": "prisma migrate dev --config ../matches-service/prisma.config.ts",
    "prisma:migrate:dev:messages": "prisma migrate dev --config ../messages-service/prisma.config.ts",
    "prisma:migrate:dev:subscriptions": "prisma migrate dev --config ../subscriptions-service/prisma.config.ts",
    "prisma:migrate:deploy:auth": "prisma migrate deploy --config ../auth-service/prisma.config.ts",
    "prisma:migrate:deploy:users": "prisma migrate deploy --config ../users-service/prisma.config.ts",
    "prisma:migrate:deploy:profiles": "prisma migrate deploy --config ../profiles-service/prisma.config.ts",
    "prisma:migrate:deploy:interactions": "prisma migrate deploy --config ../interactions-service/prisma.config.ts",
    "prisma:migrate:deploy:matches": "prisma migrate deploy --config ../matches-service/prisma.config.ts",
    "prisma:migrate:deploy:messages": "prisma migrate deploy --config ../messages-service/prisma.config.ts",
    "prisma:migrate:deploy:subscriptions": "prisma migrate deploy --config ../subscriptions-service/prisma.config.ts",
    "prisma:migrate:status:auth": "prisma migrate status --config ../auth-service/prisma.config.ts",
    "prisma:migrate:status:users": "prisma migrate status --config ../users-service/prisma.config.ts",
    "prisma:migrate:status:profiles": "prisma migrate status --config ../profiles-service/prisma.config.ts",
    "prisma:migrate:status:interactions": "prisma migrate status --config ../interactions-service/prisma.config.ts",
    "prisma:migrate:status:matches": "prisma migrate status --config ../matches-service/prisma.config.ts",
    "prisma:migrate:status:messages": "prisma migrate status --config ../messages-service/prisma.config.ts",
    "prisma:migrate:status:subscriptions": "prisma migrate status --config ../subscriptions-service/prisma.config.ts",
    "prisma:seed:auth": "ts-node ../auth-service/prisma/seed.ts",
    "start": "nest start api-gateway",
    "prestart:dev": "npm run build:contracts",
    "start:dev": "nest start api-gateway --watch",
    "prestart:dev:gateway": "npm run build:contracts",
    "start:dev:gateway": "nest start api-gateway --watch",
    "prestart:dev:auth": "npm run build:contracts",
    "start:dev:auth": "nest start auth-service --watch",
    "prestart:dev:users": "npm run build:contracts",
    "start:dev:users": "nest start users-service --watch",
    "prestart:dev:profiles": "npm run build:contracts",
    "start:dev:profiles": "nest start profiles-service --watch",
    "prestart:dev:interactions": "npm run build:contracts",
    "start:dev:interactions": "nest start interactions-service --watch",
    "prestart:dev:matches": "npm run build:contracts",
    "start:dev:matches": "nest start matches-service --watch",
    "prestart:dev:messages": "npm run build:contracts",
    "start:dev:messages": "nest start messages-service --watch",
    "prestart:dev:subscriptions": "npm run build:contracts",
    "start:dev:subscriptions": "nest start subscriptions-service --watch",
    "start:prod:gateway": "node dist/apps/api-gateway/main",
    "start:prod:auth": "node dist/apps/auth-service/main",
    "start:prod:users": "node dist/apps/users-service/main",
    "start:prod:profiles": "node dist/apps/profiles-service/main",
    "start:prod:interactions": "node dist/apps/interactions-service/main",
    "start:prod:matches": "node dist/apps/matches-service/main",
    "start:prod:messages": "node dist/apps/messages-service/main",
    "start:prod:subscriptions": "node dist/apps/subscriptions-service/main",
    "lint": "eslint \"{../api-gateway/src,../auth-service/src,../users-service/src,../profiles-service/src,../interactions-service/src,../matches-service/src,../messages-service/src,../subscriptions-service/src,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.9",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/bcrypt": "^6.0.0",
    "@types/passport-jwt": "^4.0.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.2.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.spec.json"
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "collectCoverageFrom": [
      "../api-gateway/src/**/*.(t|j)s",
      "../auth-service/src/**/*.(t|j)s",
      "../users-service/src/**/*.(t|j)s",
      "../profiles-service/src/**/*.(t|j)s",
      "../interactions-service/src/**/*.(t|j)s",
      "../matches-service/src/**/*.(t|j)s",
      "../messages-service/src/**/*.(t|j)s",
      "../subscriptions-service/src/**/*.(t|j)s",
      "libs/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  }
}
