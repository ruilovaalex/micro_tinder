generator client {
  provider = "prisma-client-js"
  output   = "../src/prisma/generated/client"
}

datasource db {
  provider = "postgresql"
}

enum InteractionType {
  LIKE
  DISLIKE
  SUPERLIKE
}

model Interaction {
  id         Int             @id @default(autoincrement())
  fromUserId Int
  toUserId   Int
  type       InteractionType
  createdAt  DateTime        @default(now())

  @@unique([fromUserId, toUserId])
}
