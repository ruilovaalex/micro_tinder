generator client {
  provider = "prisma-client-js"
  output   = "../src/prisma/generated/client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id        Int      @id
  email     String   @unique
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
}
